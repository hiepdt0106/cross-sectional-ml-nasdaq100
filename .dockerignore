data/raw/*
data/interim/*
data/processed/*
outputs/*

# Keep directory structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!outputs/.gitkeep

# Notebooks (not needed in pipeline image)
notebooks/

# Docs
*.md
LICENSE
